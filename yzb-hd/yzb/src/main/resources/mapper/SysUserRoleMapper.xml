<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.yunsheng.yzb.mapper.SysUserRoleMapper">

    <resultMap id="BaseResultMap" type="com.yunsheng.yzb.model.SysUserRole">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="role_id" property="roleId" jdbcType="BIGINT"/>
        <result column="create_by" property="createBy" jdbcType="BIGINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT id, user_id, role_id, create_by, create_time
        FROM sys_user_role
        WHERE user_id = #{userId}
    </select>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT id, user_id, role_id, create_by, create_time
        FROM sys_user_role
        WHERE role_id = #{roleId}
    </select>

    <insert id="insert" parameterType="com.yunsheng.yzb.model.SysUserRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user_role (user_id, role_id, create_by, create_time)
        VALUES (#{userId}, #{roleId}, #{createBy}, NOW())
    </insert>

    <insert id="insertBatch">
        INSERT INTO sys_user_role (user_id, role_id, create_by, create_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.roleId}, #{item.createBy}, NOW())
        </foreach>
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM sys_user_role WHERE user_id = #{userId}
    </delete>

    <delete id="deleteByRoleId">
        DELETE FROM sys_user_role WHERE role_id = #{roleId}
    </delete>

    <delete id="delete">
        DELETE FROM sys_user_role WHERE user_id = #{userId} AND role_id = #{roleId}
    </delete>

</mapper>
